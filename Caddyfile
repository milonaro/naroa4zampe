# Caddyfile per a4Zampe — Reverse proxy con HTTPS automatico
# Sostituisci il dominio con quello del comune

:80 {
	reverse_proxy app:3000 {
		header_up Host {host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote_host}
	}
}

# Per produzione con dominio e HTTPS automatico, decommenta:
