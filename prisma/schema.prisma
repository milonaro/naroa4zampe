// Schema del database per l'applicazione multi-comune "a 4 Zampe"
// Gestione segnalazioni di animali randagi - configurabile per qualsiasi comune

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Configurazione del Comune (SINGLETON) ──────────────────────────────────
// Un solo record attivo per deployment. Ogni istanza dell'app = un comune.
model Comune {
  id              String   @id @default(cuid())
  // Identità
  nomeComune      String                       // es. "Comune di Naro"
  nomeApp         String                       // es. "Naro a 4 Zampe"
  slug            String   @unique             // es. "naro" — identificativo URL-safe
  // Geografia
  latCentro       Float                        // latitudine centro abitato
  lngCentro       Float                        // longitudine centro abitato
  raggioKm        Float    @default(10)        // raggio operativo in km
  regione         String   @default("Sicilia") // regione
  provincia       String   @default("AG")      // sigla provincia
  // Contatti emergenza
  telefonoEmergenza   String?                  // es. "0922 411111"
  telefonoVeterinaria String?                  // es. "0922 412222"
  emailComune     String?                      // es. "comune@comune.naro.it"
  // Credenziali operatori (JSON)
  credenziali     String   @default("[]")      // JSON array di {username, password, nome, ruolo}
  // Branding
  colorePrimario  String   @default("yellow")  // chiave colore Tailwind
  // Stato
  attivo          Boolean  @default(true)
  setupCompletato Boolean @default(false)      // true dopo il wizard iniziale
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Utente del sistema (cittadini e amministratori)
model Utente {
  id        String   @id @default(cuid())
  email     String   @unique
  nome      String
  cognome   String
  telefono  String?
  ruolo     String   @default("cittadino") // "cittadino" oppure "amministratore"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  segnalazioni Segnalazione[]
}

// Segnalazione di animale randagio
model Segnalazione {
  id          String   @id @default(cuid())
  titolo      String
  descrizione String
  // Posizione geografica
  latitudine  Float
  longitudine Float
  indirizzo   String?
  // Dettagli dell'animale
  razza       String?
  colore      String?
  taglia      String?   // "piccola", "media", "grande"
  // Tipo di animale: "cane", "gatto", "altro"
  tipoAnimale String    @default("cane")
  // Motivazione della segnalazione: "randagismo", "abbandono", "maltrattamento", "smarrimento", "rinvenimento", "altro"
  motivazione String    @default("randagismo")
  // Urgenza: "bassa", "media", "alta", "critica"
  urgenza     String    @default("media")
  // Stato della segnalazione: "ricevuta", "in_lavorazione", "risolta", "archiviata"
  stato       String    @default("ricevuta")
  // Foto (URL o base64)
  fotoUrl     String?
  // Dati segnalatore
  nomeSegnalatore  String
  cognomeSegnalatore String
  emailSegnalatore  String
  telefonoSegnalatore String?
  // Consensi e privacy (GDPR)
  consensoPrivacy       Boolean  @default(false)  // consenso al trattamento dati
  consensoDichiarazione Boolean  @default(false)  // dichiarazione di responsabilità
  dataConsenso          DateTime?                // data in cui è stato dato il consenso
  // Zona operativa
  raggioOperativo       Float?                   // distanza in km dal centro del comune
  fuoriZona             Boolean  @default(false) // true se fuori dal raggio operativo
  // Relazioni
  utenteId    String?
  utente      Utente?  @relation(fields: [utenteId], references: [id])
  notifiche   Notifica[]
  logModifiche LogModifica[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Notifica per le autorità comunali
model Notifica {
  id             String   @id @default(cuid())
  messaggio      String
  tipo           String   @default("nuova_segnalazione") // "nuova_segnalazione", "urgenza_alta", "aggiornamento_stato"
  letta          Boolean  @default(false)
  segnalazioneId String
  segnalazione   Segnalazione @relation(fields: [segnalazioneId], references: [id])
  createdAt      DateTime @default(now())
}

// Token di accesso per Area Personale (verifica via email)
model TokenAccesso {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  usato     Boolean  @default(false)
  scadenza  DateTime
  createdAt DateTime @default(now())
}

// Log delle modifiche apportate alle segnalazioni
model LogModifica {
  id               String   @id @default(cuid())
  campoModificato  String   // e.g. "stato"
  valorePrecedente String   // valore precedente
  valoreNuovo      String   // nuovo valore
  modificatoDa     String   // email dell'admin che ha effettuato la modifica
  segnalazioneId   String
  segnalazione     Segnalazione @relation(fields: [segnalazioneId], references: [id])
  createdAt        DateTime @default(now())
}
